  /* ============================================================================= */
  /* COMPLETE BORDER COLOR MAPPING SYSTEM */
  /* ============================================================================= */
  
  /* Border colors for all Tailwind utilities */
  --tw-border-white: var(--component-card-border);
  --tw-border-gray-100: var(--glass-border-subtle);
  --tw-border-gray-200: var(--glass-border-medium);
  --tw-border-gray-300: var(--border);
  --tw-border-gray-400: var(--muted);
  --tw-border-gray-500: var(--muted-foreground);
  --tw-border-gray-600: oklch(0.4000 0.0300 260);
  --tw-border-gray-700: var(--card);
  --tw-border-slate-100: var(--glass-border-subtle);
  --tw-border-slate-200: var(--glass-border-medium);
  --tw-border-slate-300: var(--border);
  --tw-border-neutral-200: var(--glass-border-medium);
  --tw-border-neutral-300: var(--border);
  --tw-border-stone-200: var(--glass-border-medium);
  --tw-border-stone-300: var(--border);
  --tw-border-zinc-200: var(--glass-border-medium);
  --tw-border-zinc-300: var(--border);
  
  /* Colored borders */
  --tw-border-red-500: var(--error-text);
  --tw-border-orange-500: var(--cardiology-accent-orange);
  --tw-border-yellow-500: oklch(0.7200 0.1600 75);
  --tw-border-green-500: var(--status-success);
  --tw-border-emerald-500: var(--cardiology-accent-emerald);
  --tw-border-blue-500: var(--cardiology-accent-blue);
  --tw-border-indigo-500: oklch(0.6200 0.1400 272);
  --tw-border-violet-500: oklch(0.6200 0.1400 295);
  --tw-border-purple-500: oklch(0.6200 0.1400 320);

  /* Badge system - complete mapping */
  --badge-default: var(--component-card);
  --badge-default-foreground: var(--foreground);
  --badge-secondary: var(--component-surface-secondary);
  --badge-secondary-foreground: var(--foreground-secondary);
  --badge-success: oklch(0.9400 0.0600 145 / 0.85);
  --badge-success-foreground: oklch(0.2000 0.1200 145);
  --badge-warning: oklch(0.9400 0.0800 45 / 0.85);
  --badge-warning-foreground: oklch(0.2000 0.1200 45);
  --badge-error: oklch(0.9400 0.0800 15 / 0.85);
  --badge-error-foreground: oklch(0.2000 0.1200 15);
  --badge-info: oklch(0.9400 0.0600 242 / 0.85);
  --badge-info-foreground: oklch(0.2000 0.1200 242);
}