  /* ============================================================================= */
  /* COMPLETE TEXT COLOR MAPPING SYSTEM */
  /* ============================================================================= */
  
  /* Text colors for all Tailwind utilities */
  --tw-text-white: var(--foreground);
  --tw-text-black: var(--background);
  
  --tw-text-gray-50: oklch(0.9700 0.0100 260);
  --tw-text-gray-100: oklch(0.9300 0.0150 260);
  --tw-text-gray-200: oklch(0.8800 0.0200 260);
