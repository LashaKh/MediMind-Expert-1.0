  /* Colored text - use cardiology theme colors */
  --tw-text-red-500: var(--error-text);
  --tw-text-red-600: var(--error-text);
  --tw-text-red-700: oklch(0.4000 0.1600 15);
  --tw-text-orange-500: var(--cardiology-accent-orange);
